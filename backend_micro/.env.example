# ============================================================
# MICRO-SERVICIOS — Variables de Entorno Unificadas
# Copiar como .env y rellenar los valores reales
# ============================================================

# ====================================
# EMAIL / CONTACTO (Landing page)
# ====================================
SMTP_SERVER=smtp.ionos.mx
SMTP_PORT=465
SMTP_USERNAME=contacto@micro-servicios.com.mx
SMTP_PASSWORD=your_password_here
RECIPIENT_EMAIL=contacto@micro-servicios.com.mx

# ====================================
# EXCEL CONVERTER
# ====================================
DATABASE_URL=sqlite:///./excel_converter.db
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
JWT_SECRET=change-this-jwt-secret
OPENAI_API_KEY=sk-...

# PayPal — Excel Converter
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox

# ====================================
# ESTRUCTURA POLÍTICA (prefijo EP_)
# ====================================
EP_DB_HOST=localhost
EP_DB_PORT=3306
EP_DB_USER=root
EP_DB_PASSWORD=your_password_here
EP_DB_NAME=estructura_politica

EP_SECRET_KEY=your_super_secret_key_change_this_in_production
EP_ALGORITHM=HS256
EP_ACCESS_TOKEN_EXPIRE_MINUTES=1440

EP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
EP_GOOGLE_CLIENT_SECRET=your_google_client_secret

EP_MICROSOFT_CLIENT_ID=your_microsoft_client_id
EP_MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
EP_MICROSOFT_TENANT_ID=common

EP_PAYPAL_MODE=sandbox
EP_PAYPAL_CLIENT_ID=your_paypal_client_id
EP_PAYPAL_CLIENT_SECRET=your_paypal_client_secret
EP_PAYPAL_WEBHOOK_ID=your_webhook_id
EP_PAYPAL_CURRENCY=MXN
EP_PAYPAL_AMOUNT=20.00
EP_PAYPAL_RETURN_URL=https://micro-servicios.com.mx/registro/exito
EP_PAYPAL_CANCEL_URL=https://micro-servicios.com.mx/registro/cancelado

EP_SMTP_HOST=smtp.gmail.com
EP_SMTP_PORT=587
EP_SMTP_USER=your_email@gmail.com
EP_SMTP_PASSWORD=your_app_password
EP_SMTP_FROM_EMAIL=noreply@micro-servicios.com.mx
EP_SMTP_FROM_NAME=Sistema Electoral

EP_APP_NAME=Sistema Multi-Tenant Electoral
EP_APP_VERSION=1.0.0
EP_API_URL=http://localhost:8000
EP_FRONTEND_URL=http://localhost:5173
EP_UPLOAD_DIR=uploads
EP_MAX_UPLOAD_SIZE_MB=10

EP_BASE_DOMAIN=micro-servicios.com.mx
EP_ALLOW_LOCALHOST=true
EP_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
EP_ALLOWED_HOSTS=*
EP_ENCRYPTION_KEY=your_encryption_key_for_sensitive_data_32_chars_minimum

# ====================================
# MESA DE REGALOS (prefijo MR_)
# ====================================
MR_DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/mesa_de_regalos

MR_ML_CAMP_ID=tu_campaign_id_de_mercadolibre

MR_PAYPAL_CLIENT_ID=tu_client_id_aqui
MR_PAYPAL_SECRET=tu_secret_aqui
MR_PAYPAL_MODE=sandbox
MR_PAYPAL_PLAN_ID=tu_plan_id_aqui

MR_GOOGLE_CLIENT_ID=tu_google_client_id_aqui.apps.googleusercontent.com

MR_FRONTEND_URL=https://micro-servicios.com.mx
MR_SECRET_KEY=tu_clave_secreta_para_jwt_aqui
MR_ACCESS_TOKEN_EXPIRE_MINUTES=1440
